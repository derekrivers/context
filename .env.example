# Context backend configuration.
# Copy to .env and fill in values. All CONTEXT_* vars are read by packages/backend.

# Node environment: development | production | test
CONTEXT_NODE_ENV=development

# Fastify bind address and port
CONTEXT_HOST=0.0.0.0
CONTEXT_PORT=8180

# Log level: fatal | error | warn | info | debug | trace | silent
CONTEXT_LOG_LEVEL=info

# --- Postgres (node-postgres pool + drizzle) ---
# Matches the credentials in docker-compose.yml so `pnpm --filter @context/backend db:migrate`
# works out of the box against the local container.
CONTEXT_PG_HOST=localhost
CONTEXT_PG_PORT=5432
CONTEXT_PG_USER=context
CONTEXT_PG_PASSWORD=context
CONTEXT_PG_DATABASE=context

# Enable TLS when connecting to Postgres (true | false). Leave false for local docker-compose.
CONTEXT_PG_SSL=false

# Maximum pool size. Tune up for production.
CONTEXT_PG_POOL_MAX=10

# --- Operator / admin auth ---
# Long random string (>= 16 chars). Used to authorize POST /users for bootstrapping.
# Rotate by redeploying with a new value. Never share or commit real values.
CONTEXT_ADMIN_TOKEN=replace-me-with-a-long-random-string

# --- Anthropic LLM access ---
# Required for the conversation engine (phrase + parse). Get one at console.anthropic.com.
ANTHROPIC_API_KEY=sk-ant-replace-me

# --- Context LLM configuration ---
# Haiku is plenty for phrasing questions (conversational, high-volume).
CONTEXT_PHRASE_MODEL=claude-haiku-4-5-20251001

# Sonnet for parsing answers (reliability matters when turning free text into updates).
CONTEXT_PARSE_MODEL=claude-sonnet-4-6

# Per-call timeout for LLM requests (ms). Applies to both phrase and parse.
CONTEXT_LLM_TIMEOUT_MS=30000

# Hard cap on turns per spec. nextTurn returns a cap signal once crossed.
CONTEXT_MAX_TURNS_PER_SPEC=60

# Hard cap on input+output tokens summed across all turns for a spec.
CONTEXT_MAX_TOKENS_PER_SPEC=500000

# --- Context frontend ---
# Dev server port for the Vite app. The dev proxy forwards /api → backend.
CONTEXT_FRONTEND_PORT=5174

# Backend URL the frontend's API client talks to. In dev this is proxied
# via /api; in production, set to the public backend URL.
CONTEXT_BACKEND_URL=http://127.0.0.1:8180
