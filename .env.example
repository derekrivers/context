# Context backend configuration.
# Copy to .env and fill in values. All CONTEXT_* vars are read by packages/backend.

# Node environment: development | production | test
CONTEXT_NODE_ENV=development

# Fastify bind address and port
CONTEXT_HOST=0.0.0.0
CONTEXT_PORT=8180

# Log level: fatal | error | warn | info | debug | trace | silent
CONTEXT_LOG_LEVEL=info

# --- Postgres (node-postgres pool + drizzle) ---
# Matches the credentials in docker-compose.yml so `pnpm --filter @context/backend db:migrate`
# works out of the box against the local container.
CONTEXT_PG_HOST=localhost
CONTEXT_PG_PORT=5432
CONTEXT_PG_USER=context
CONTEXT_PG_PASSWORD=context
CONTEXT_PG_DATABASE=context

# Enable TLS when connecting to Postgres (true | false). Leave false for local docker-compose.
CONTEXT_PG_SSL=false

# Maximum pool size. Tune up for production.
CONTEXT_PG_POOL_MAX=10
